# Required — GCP project hosting Vertex AI
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# Region for main Vertex AI services
GOOGLE_CLOUD_LOCATION=asia-southeast1

# Vertex AI RAG Corpus full resource path
VERTEX_RAG_CORPUS_PATH=projects/PROJECT_NUMBER/locations/LOCATION/ragCorpora/CORPUS_ID

# ADK agent model
DEMO_AGENT_MODEL=gemini-live-2.5-flash-native-audio

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=star_learners_kb
# QDRANT_API_KEY=   # only needed for cloud Qdrant

# Gemini embedding models
GEMINI_TEXT_EMBED_MODEL=gemini-embedding-001
GEMINI_IMAGE_EMBED_MODEL=multimodalembedding@001
GEMINI_CAPTION_MODEL=gemini-2.0-flash
